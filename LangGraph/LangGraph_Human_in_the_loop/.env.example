# AWS Bedrock (credentials come from AWS credential chain: sso login / env vars / ~/.aws)
AWS_PROFILE=xxxxxx
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=arn:aws:bedrock:eu-central-1:xxxxxxxx:inference-profile/eu.anthropic.claude-sonnet-4-6

# Arize Phoenix
PHOENIX_ENDPOINT=http://localhost:6006/
PHOENIX_PROJECT_NAME=financial-doc-analyst

# App
LOG_LEVEL=INFO
DATA_DIR=data/
RESULTS_DIR=results/

# MCP Tool Server
MCP_TRANSPORT=stdio          # stdio (local, subprocess) | sse (separate process / Docker)
MCP_SERVER_HOST=localhost    # SSE mode only
MCP_SERVER_PORT=8000         # SSE mode only
